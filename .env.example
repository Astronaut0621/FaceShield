# FaceShield environment example
# Copy this file to .env and adjust values for your machine.

# Backend database. SQLite is enough for local development.
DATABASE_URL=sqlite:///D:/FaceShield/backend/faceshield.db

# Demo login account created during backend startup.
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123456
DEMO_DISPLAY_NAME=Demo User

# Frontend origins allowed by FastAPI CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Algorithm backend:
# - mock: no Paddle dependency, good for frontend/API walkthrough.
# - paddle: load model/deploy/fusion_v2 and generate Paddle Grad-CAM heatmaps.
FACESHIELD_ALGORITHM_BACKEND=mock
FACESHIELD_MODEL_NAME=FaceShield-FusionV2
FACESHIELD_MODEL_VERSION=fusion_v2-202607
FACESHIELD_MODEL_PATH=D:/FaceShield/model/deploy/fusion_v2/best.pdparams
FACESHIELD_MODEL_CONFIG_PATH=D:/FaceShield/model/deploy/fusion_v2/config.json

# Optional frontend config if you run frontend separately without Vite proxy.
VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_STORAGE_BASE_URL=http://127.0.0.1:8000
